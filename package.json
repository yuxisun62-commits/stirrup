{
  "name": "stirrup-ai",
  "version": "0.1.3",
  "description": "DAG workflow engine with AI-powered nodes — design, run, and deploy workflows from CLI, UI, or code",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "bin/",
    "schemas/",
    "templates/",
    "plugins/public/",
    "src/ui/dist/",
    "LICENSE",
    "README.md",
    "AGENT-USAGE.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PrincipalForce/stirrup"
  },
  "homepage": "https://github.com/PrincipalForce/stirrup#readme",
  "bin": {
    "stirrup": "./bin/stirrup.js",
    "stirrup-mcp": "./bin/stirrup-mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "build:ui": "cd ui && npm run build",
    "build:all": "npm run build:ui && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "node dist/cli/index.js",
    "dev:ui": "cd ui && npm run dev"
  },
  "keywords": [
    "workflow",
    "dag",
    "ai",
    "claude",
    "automation",
    "pipeline",
    "orchestration",
    "llm",
    "mcp",
    "agent",
    "deterministic",
    "workflow-engine",
    "stirrup"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "@inquirer/prompts": "^8.4.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.18.0",
    "better-sqlite3": "^12.8.0",
    "chalk": "^5.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "ora": "^9.3.0",
    "uuid": "^11.1.0",
    "yaml": "^2.8.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "@types/yargs": "^17.0.35",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
