{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkflowDefinition",
  "description": "Schema for workflow harness definition files",
  "type": "object",
  "required": ["id", "name", "version", "nodes", "edges"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "description": { "type": "string" },
    "params": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["string", "number", "boolean", "json"] },
          "description": { "type": "string" },
          "required": { "type": "boolean" },
          "default": {},
          "service": { "type": "string" },
          "picker": {
            "type": "string",
            "description": "If set, the Run Workflow dialog renders a typed picker UI instead of a plain text input. 'github-repo' shows a searchable list of the user's accessible repos.",
            "enum": ["github-repo"]
          }
        },
        "additionalProperties": false
      }
    },
    "context": { "type": "object" },
    "triggers": {
      "type": "object",
      "properties": {
        "http": {
          "type": "object",
          "properties": {
            "path": { "type": "string" },
            "method": { "type": "string", "enum": ["POST", "GET"] }
          },
          "additionalProperties": false
        },
        "webhook": {
          "type": "object",
          "required": ["source"],
          "properties": {
            "source": { "type": "string" },
            "events": { "type": "array", "items": { "type": "string" } },
            "secret": { "type": "string" }
          },
          "additionalProperties": false
        },
        "cron": {
          "type": "object",
          "required": ["schedule"],
          "properties": {
            "schedule": { "type": "string" },
            "timezone": { "type": "string" }
          },
          "additionalProperties": false
        },
        "watch": {
          "type": "object",
          "required": ["paths"],
          "properties": {
            "paths": { "type": "array", "items": { "type": "string" } },
            "events": {
              "type": "array",
              "items": { "type": "string", "enum": ["create", "change", "delete"] }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/WorkflowNode" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/definitions/WorkflowEdge" }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "retry": { "$ref": "#/definitions/RetryPolicy" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "definitions": {
    "WorkflowNode": {
      "type": "object",
      "required": ["id", "type", "name", "inputs", "outputs", "config"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string", "minLength": 1 },
              "to": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "config": { "type": "object" },
        "retry": { "$ref": "#/definitions/RetryPolicy" },
        "branches": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "continueOnError": {
          "type": "boolean",
          "description": "If true, a failed node lets execution continue. Downstream can inspect the failed step's error field."
        }
      },
      "additionalProperties": false
    },
    "WorkflowEdge": {
      "type": "object",
      "required": ["from", "to"],
      "properties": {
        "from": { "type": "string", "minLength": 1 },
        "to": { "type": "string", "minLength": 1 },
        "condition": { "type": "string" }
      },
      "additionalProperties": false
    },
    "RetryPolicy": {
      "type": "object",
      "required": ["maxAttempts", "backoffMs", "backoffMultiplier"],
      "properties": {
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "backoffMs": { "type": "integer", "minimum": 0 },
        "backoffMultiplier": { "type": "number", "minimum": 1 },
        "retryableErrors": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
